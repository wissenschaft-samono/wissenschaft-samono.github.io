---
import { SITE } from '@/site.config';
---

<header class="site-header">
  <div class="site-shell header-inner">
    <a class="site-title" href="/">{SITE.title}</a>
    <p>{SITE.subtitle}</p>
    <nav aria-label="主要ナビゲーション">
      <a href="/">Home</a>
      <a href="/archive/">Archive</a>
      <a href="/categories/">Categories</a>
      <a href="/about/">About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(rgba(253, 252, 249, 0.6), rgba(253, 252, 249, 0.76)),
      url('/images/header-source.jpeg');
    background-color: var(--surface);
    background-position: center 45%;
    background-size: cover;
  }

  .header-inner {
    min-height: 320px;
    display: grid;
    align-content: end;
    padding: 5.6rem 0 1.9rem;
  }

  .site-title {
    color: var(--text);
    font-size: clamp(2rem, 6vw, 3.2rem);
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    text-shadow: 0 1px 18px rgba(253, 252, 249, 0.85);
  }

  p {
    margin: 0.3rem 0 0.45rem;
    color: var(--muted);
    font-size: 0.95rem;
    text-shadow: 0 1px 14px rgba(253, 252, 249, 0.9);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.9rem;
  }

  nav a {
    text-shadow: 0 1px 12px rgba(253, 252, 249, 0.9);
  }

  @media (max-width: 899px) {
    .header-inner {
      min-height: 240px;
      padding: 3.8rem 0 1.4rem;
    }

    p {
      max-width: 28rem;
      font-size: 0.86rem;
      line-height: 1.55;
    }
  }
</style>

---
import ProfileBlock from '@/components/ProfileBlock.astro';
import { categoryPath, formatDate, getArchiveYears, getCategories, getRecentPosts } from '@/lib/posts';

const recentPosts = await getRecentPosts(10);
const categories = await getCategories();
const archiveYears = getArchiveYears(recentPosts);
---

<aside class="sidebar" aria-label="サイドバー">
  <ProfileBlock />

  <section>
    <h2>Recent Entries</h2>
    <ol>
      {recentPosts.map((post) => (
        <li>
          <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        </li>
      ))}
    </ol>
  </section>

  <section>
    <h2>Categories</h2>
    <ul>
      {categories.map((category) => (
        <li><a href={categoryPath(category.name)}>{category.name}</a> <span>({category.count})</span></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Archive</h2>
    <ul>
      {archiveYears.map(([year]) => <li><a href="/archive/">{year}</a></li>)}
    </ul>
  </section>
</aside>

<style>
  .sidebar {
    color: var(--muted);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-top: var(--blog-sidebar-offset);
  }

  :global(.profile-block),
  section {
    padding: 0 0 1.4rem;
    margin: 0 0 1.4rem;
    border-bottom: 1px solid var(--line);
  }

  :global(.profile-block:last-child),
  section:last-child {
    margin-bottom: 0;
    border-bottom: 0;
  }

  h2 {
    margin: 0 0 0.55rem;
    color: var(--text);
    font-size: 0.95rem;
    letter-spacing: 0;
  }

  a {
    text-decoration-thickness: 0.06em;
  }

  p {
    margin: 0.35rem 0;
  }

  ul,
  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    margin: 0.35rem 0;
  }

  time {
    display: block;
    font-size: 0.78rem;
  }

  @media (max-width: 899px) {
    .sidebar {
      margin-top: 2.5rem;
      padding: 1.25rem 1rem 0.2rem;
      border: 1px solid var(--line);
      background: color-mix(in srgb, var(--surface) 72%, var(--bg));
    }

  }
</style>

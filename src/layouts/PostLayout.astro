---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostMeta from '@/components/PostMeta.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  previousPost?: CollectionEntry<'posts'>;
  nextPost?: CollectionEntry<'posts'>;
}

const { post, previousPost, nextPost } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description} canonical={post.data.canonicalUrl}>
  <article class="post">
    <header>
      <h1 class="page-title">{post.data.title}</h1>
      <PostMeta post={post} />
      <p class="lead">{post.data.description}</p>
    </header>

    {post.data.relatedWork && (
      <aside class="related-work" aria-label="この記事と研究成果との関係">
        <h2>この記事と研究成果との関係</h2>
        <p>{post.data.relatedWork}</p>
      </aside>
    )}

    <div class="prose">
      <slot />
    </div>

    <nav class="post-nav" aria-label="前後の記事">
      {nextPost ? <a href={`/posts/${nextPost.id}/`}>← {nextPost.data.title}</a> : <span />}
      {previousPost ? <a href={`/posts/${previousPost.id}/`}>{previousPost.data.title} →</a> : <span />}
    </nav>
  </article>
</BaseLayout>

<style>
  .lead {
    margin: 1rem 0 1.8rem;
    color: var(--muted);
  }

  .related-work {
    margin: 1.5rem 0 2rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .related-work h2 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
  }

  .related-work p {
    margin: 0;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.92rem;
  }

  .post-nav a:last-child {
    text-align: right;
  }
</style>

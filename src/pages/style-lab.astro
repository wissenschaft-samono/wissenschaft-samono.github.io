---
import '@/styles/theme.css';
import '@/styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>見た目調整 | 風呂は命の洗濯</title>
  </head>
  <body class="lab-page">
    <main class="lab-shell">
      <header class="lab-header">
        <div>
          <p class="eyebrow">Style Studio</p>
          <h1>見た目調整</h1>
          <p>本物のブログ画面を見ながら、幅・余白・文字・色をスライダーで調整できます。</p>
        </div>
        <a href="/">ブログへ戻る</a>
      </header>

      <section class="studio">
        <aside class="controls" aria-label="調整パネル">
          <div class="control-group">
            <h2>プレビュー</h2>
            <div class="segmented" aria-label="表示ページ">
              <button type="button" data-page="/" class="active">トップ</button>
              <button type="button" data-page="/posts/sample-reading-note/">記事</button>
              <button type="button" data-page="/about/">About</button>
            </div>
            <label>
              <span>画面幅</span>
              <input id="screenWidth" type="range" min="390" max="1500" step="10" value="1360" />
              <output id="screenWidthValue">1360px</output>
            </label>
          </div>

          <div class="control-group">
            <h2>幅と余白</h2>
            <label>
              <span>ページ全体</span>
              <input data-key="page" type="range" min="980" max="1520" step="10" />
              <output data-value="page"></output>
            </label>
            <label>
              <span>本文幅</span>
              <input data-key="main" type="range" min="680" max="1080" step="10" />
              <output data-value="main"></output>
            </label>
            <label>
              <span>Profile幅</span>
              <input data-key="sidebar" type="range" min="200" max="340" step="10" />
              <output data-value="sidebar"></output>
            </label>
            <label>
              <span>本文とProfileの間</span>
              <input data-key="gap" type="range" min="24" max="120" step="4" />
              <output data-value="gap"></output>
            </label>
            <label>
              <span>外側の余白</span>
              <input data-key="sidePadding" type="range" min="0" max="64" step="2" />
              <output data-value="sidePadding"></output>
            </label>
            <label>
              <span>スマホ余白</span>
              <input data-key="mobileSidePadding" type="range" min="8" max="32" step="2" />
              <output data-value="mobileSidePadding"></output>
            </label>
            <label>
              <span>Profileの下げ幅</span>
              <input data-key="offset" type="range" min="0" max="80" step="2" />
              <output data-value="offset"></output>
            </label>
          </div>

          <div class="control-group">
            <h2>文字</h2>
            <label>
              <span>本文サイズ</span>
              <input data-key="font" type="range" min="15" max="20" step="0.5" />
              <output data-value="font"></output>
            </label>
            <label>
              <span>スマホ本文</span>
              <input data-key="mobileFont" type="range" min="14" max="18" step="0.5" />
              <output data-value="mobileFont"></output>
            </label>
            <label>
              <span>行間</span>
              <input data-key="lineHeight" type="range" min="1.55" max="2.2" step="0.05" />
              <output data-value="lineHeight"></output>
            </label>
          </div>

          <div class="control-group">
            <h2>色</h2>
            <label class="color-row">
              <span>背景</span>
              <input data-key="background" type="color" />
            </label>
            <label class="color-row">
              <span>文字</span>
              <input data-key="text" type="color" />
            </label>
            <label class="color-row">
              <span>薄い文字</span>
              <input data-key="muted" type="color" />
            </label>
            <label class="color-row">
              <span>アクセント</span>
              <input data-key="link" type="color" />
            </label>
            <label class="color-row">
              <span>線</span>
              <input data-key="border" type="color" />
            </label>
          </div>

          <div class="control-group">
            <h2>プリセット</h2>
            <div class="preset-grid">
              <button type="button" data-preset="current">現在</button>
              <button type="button" data-preset="wide">本文広め</button>
              <button type="button" data-preset="soft">柔らかめ</button>
              <button type="button" data-preset="compact">余白少なめ</button>
            </div>
          </div>
        </aside>

        <section class="preview-column" aria-label="実際のブログプレビュー">
          <div class="preview-toolbar">
            <div>
              <strong>ライブプレビュー</strong>
              <span>本物のページに一時的な見た目設定をかけています。</span>
            </div>
            <button type="button" id="copyButton">反映用の値をコピー</button>
          </div>

          <div class="preview-stage">
            <iframe id="previewFrame" src="/" title="ブログの見た目プレビュー"></iframe>
          </div>

          <section class="readout" aria-label="反映用の値">
            <div>
              <h2>反映用の値</h2>
              <p>気に入ったら、この内容をそのまま送ってください。</p>
            </div>
            <textarea id="cssOutput" readonly></textarea>
          </section>
        </section>
      </section>
    </main>

    <script>
      // @ts-nocheck
      const initial = {
        background: '#fdfcf9',
        text: '#1f1f1f',
        muted: '#6b6760',
        link: '#5a4a78',
        border: '#dedbd4',
        font: 17,
        mobileFont: 16,
        lineHeight: 1.9,
        page: 1400,
        main: 1000,
        sidebar: 300,
        gap: 64,
        offset: 18,
        sidePadding: 10,
        mobileSidePadding: 14,
      };

      const state = { ...initial };
      const frame = document.querySelector('#previewFrame');
      const cssOutput = document.querySelector('#cssOutput');
      const copyButton = document.querySelector('#copyButton');
      const screenWidth = document.querySelector('#screenWidth');
      const screenWidthValue = document.querySelector('#screenWidthValue');
      const inputs = document.querySelectorAll('[data-key]');
      const outputs = document.querySelectorAll('[data-value]');
      const pageButtons = document.querySelectorAll('[data-page]');
      const presetButtons = document.querySelectorAll('[data-preset]');

      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function darken(hex) {
        const color = hex.replace('#', '');
        const parts = [0, 2, 4].map((start) => parseInt(color.slice(start, start + 2), 16));
        return `#${parts.map((part) => clamp(part - 30, 0, 255).toString(16).padStart(2, '0')).join('')}`;
      }

      function vars() {
        return {
          '--blog-background': state.background,
          '--blog-text': state.text,
          '--blog-muted-text': state.muted,
          '--blog-link': state.link,
          '--blog-link-hover': darken(state.link),
          '--blog-border': state.border,
          '--blog-font-size': `${state.font}px`,
          '--blog-mobile-font-size': `${state.mobileFont}px`,
          '--blog-line-height': state.lineHeight,
          '--blog-page-width': `${state.page}px`,
          '--blog-main-width': `${state.main}px`,
          '--blog-sidebar-width': `${state.sidebar}px`,
          '--blog-column-gap': `${state.gap}px`,
          '--blog-sidebar-offset': `${state.offset}px`,
          '--blog-side-padding': `${state.sidePadding}px`,
          '--blog-mobile-side-padding': `${state.mobileSidePadding}px`,
        };
      }

      function syncControls() {
        inputs.forEach((input) => {
          input.value = state[input.dataset.key];
        });
        outputs.forEach((output) => {
          const value = state[output.dataset.value];
          output.textContent = typeof value === 'number' && output.dataset.value !== 'lineHeight' ? `${value}px` : value;
        });
      }

      function applyToFrame() {
        const doc = frame.contentDocument;
        if (!doc) return;
        const root = doc.documentElement;
        Object.entries(vars()).forEach(([name, value]) => root.style.setProperty(name, value));
      }

      function updateOutput() {
        cssOutput.value = Object.entries(vars()).map(([name, value]) => `${name}: ${value};`).join('\n');
      }

      function applyAll() {
        syncControls();
        applyToFrame();
        updateOutput();
      }

      function setPreset(name) {
        if (name === 'current') Object.assign(state, initial);
        if (name === 'wide') Object.assign(state, { page: 1480, main: 1040, sidebar: 320, gap: 72, sidePadding: 8 });
        if (name === 'soft') Object.assign(state, { background: '#fffdf8', muted: '#766f68', link: '#6a527d', border: '#e5ded5', font: 17.5, lineHeight: 1.95 });
        if (name === 'compact') Object.assign(state, { page: 1360, main: 960, sidebar: 280, gap: 44, sidePadding: 4 });
        applyAll();
      }

      inputs.forEach((input) => {
        input.addEventListener('input', () => {
          state[input.dataset.key] = input.type === 'color' ? input.value : Number(input.value);
          applyAll();
        });
      });

      screenWidth.addEventListener('input', () => {
        frame.style.width = `${screenWidth.value}px`;
        screenWidthValue.textContent = `${screenWidth.value}px`;
      });

      pageButtons.forEach((button) => {
        button.addEventListener('click', () => {
          pageButtons.forEach((item) => item.classList.remove('active'));
          button.classList.add('active');
          frame.src = button.dataset.page;
        });
      });

      presetButtons.forEach((button) => {
        button.addEventListener('click', () => setPreset(button.dataset.preset));
      });

      copyButton.addEventListener('click', async () => {
        await navigator.clipboard.writeText(cssOutput.value);
        copyButton.textContent = 'コピーしました';
        setTimeout(() => {
          copyButton.textContent = '反映用の値をコピー';
        }, 1200);
      });

      frame.addEventListener('load', applyToFrame);
      frame.style.width = `${screenWidth.value}px`;
      applyAll();
    </script>
  </body>
</html>

<style>
  .lab-page {
    background: #f5f3ee;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'YuGothic', system-ui, sans-serif;
  }

  .lab-shell {
    width: min(1520px, calc(100% - 24px));
    margin: 0 auto;
    padding: 1rem 0 2.5rem;
  }

  .lab-header {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: start;
    padding: 0.8rem 0 1rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--blog-link);
    font-size: 0.85rem;
    font-weight: 700;
  }

  h1 {
    margin: 0.1rem 0 0.25rem;
    font-size: 1.7rem;
    line-height: 1.35;
  }

  .lab-header p:last-child {
    margin: 0;
    color: #68625d;
  }

  .studio {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .controls,
  .preview-column,
  .readout {
    border: 1px solid #ddd6cd;
    background: #fffdf8;
  }

  .controls {
    position: sticky;
    top: 12px;
    max-height: calc(100vh - 24px);
    overflow: auto;
    padding: 1rem;
    font-size: 0.9rem;
  }

  .control-group + .control-group {
    margin-top: 1.15rem;
    padding-top: 1.15rem;
    border-top: 1px solid #e3dcd2;
  }

  .control-group h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }

  label {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.35rem 0.65rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  label input[type='range'] {
    grid-column: 1 / -1;
    width: 100%;
  }

  output {
    min-width: 58px;
    color: var(--blog-link);
    font-weight: 700;
    text-align: right;
  }

  input[type='color'] {
    width: 76px;
    height: 34px;
    border: 1px solid #ddd6cd;
    background: white;
  }

  .color-row {
    grid-template-columns: 1fr auto;
  }

  .segmented,
  .preset-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.45rem;
    margin-bottom: 0.8rem;
  }

  .preset-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  button {
    border: 1px solid var(--blog-link);
    padding: 0.55rem 0.65rem;
    background: transparent;
    color: var(--blog-link);
    font: inherit;
    cursor: pointer;
  }

  button.active,
  button:hover,
  #copyButton {
    background: var(--blog-link);
    color: white;
  }

  .preview-column {
    min-width: 0;
  }

  .preview-toolbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid #ddd6cd;
  }

  .preview-toolbar span {
    display: block;
    color: #756e68;
    font-size: 0.88rem;
  }

  .preview-stage {
    overflow: auto;
    min-height: 640px;
    padding: 22px;
    background:
      linear-gradient(90deg, rgba(90, 74, 120, 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgba(90, 74, 120, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  iframe {
    display: block;
    width: 1360px;
    height: 760px;
    min-width: 390px;
    border: 1px solid #cfc6bb;
    background: white;
    box-shadow: 0 14px 36px rgba(31, 31, 31, 0.12);
  }

  .readout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1rem;
    align-items: start;
    margin: 1rem;
    padding: 1rem;
  }

  .readout h2 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
  }

  .readout p {
    margin: 0;
    color: #756e68;
    font-size: 0.88rem;
  }

  textarea {
    width: 100%;
    min-height: 160px;
    resize: vertical;
    border: 1px solid #ddd6cd;
    padding: 0.75rem;
    background: #fffaf1;
    color: #1f1f1f;
    font: 0.82rem/1.6 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  @media (max-width: 1050px) {
    .studio {
      display: block;
    }

    .controls {
      position: static;
      max-height: none;
      margin-bottom: 1rem;
    }

    .readout {
      display: block;
    }

    textarea {
      margin-top: 0.75rem;
    }
  }
</style>

---
import '@/styles/theme.css';
import '@/styles/global.css';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>見た目調整 | 風呂は命の洗濯</title>
  </head>
  <body class="lab-page">
    <main class="lab-shell">
      <header class="lab-header">
        <div>
          <p class="eyebrow">Style Lab</p>
          <h1>見た目調整</h1>
          <p>下のプレビューを見ながら、紫のつまみやスライダーで幅・余白・色を試せます。</p>
        </div>
        <a href="/">ブログへ戻る</a>
      </header>

      <section class="control-panel" aria-label="調整パネル">
        <label>
          全体幅
          <input id="pageRange" type="range" min="980" max="1240" value="1160" />
          <span><output id="pageValue">1160</output>px</span>
        </label>

        <label>
          本文幅
          <input id="mainRange" type="range" min="620" max="840" value="740" />
          <span><output id="mainValue">740</output>px</span>
        </label>

        <label>
          サイドバー幅
          <input id="sidebarRange" type="range" min="220" max="340" value="260" />
          <span><output id="sidebarValue">260</output>px</span>
        </label>

        <label>
          間隔
          <input id="gapRange" type="range" min="32" max="96" value="56" />
          <span><output id="gapValue">56</output>px</span>
        </label>

        <label>
          サイドバーの下げ幅
          <input id="offsetRange" type="range" min="0" max="64" value="18" />
          <span><output id="offsetValue">18</output>px</span>
        </label>

        <label>
          文字サイズ
          <input id="fontRange" type="range" min="16" max="19" value="17" step="0.5" />
          <span><output id="fontValue">17</output>px</span>
        </label>

        <label>
          アクセント色
          <input id="linkColor" type="color" value="#5a4a78" />
        </label>
      </section>

      <section class="preview-area" aria-label="ブログの見た目プレビュー">
        <div class="preview-toolbar">
          <p>
            <strong>ドラッグ:</strong>
            本文とサイドバーの境目を動かすと、片方が広がり、もう片方が狭くなります。右端を動かすと全体幅が変わります。
          </p>
        </div>

        <div class="preview-canvas">
          <div class="mock-page" id="mockPage">
            <div class="mock-header">
              <strong>風呂は命の洗濯</strong>
              <span>Literature, Phenomenology &amp; Criticism</span>
            </div>

            <div class="mock-layout">
              <article class="mock-main">
                <p class="mock-meta">2026年6月1日 / 読書メモ</p>
                <h2>本文エリア</h2>
                <p>
                  ここが記事本文です。日本語の長文を読んだときに、横幅が広すぎないか、狭すぎないかを見ます。
                  右側の欄との距離も、読み心地にかなり影響します。
                </p>
                <p>
                  境目の紫のつまみを左右に動かすと、本文とサイドバーの幅が連動して変わります。
                  右端のつまみを動かすと、ページ全体の幅が変わります。
                </p>
                <blockquote>引用や補足が入ったときの見え方も、この幅で確認できます。</blockquote>
              </article>

              <div class="divider-handle" id="dividerHandle" role="separator" aria-label="本文とサイドバーの境目を調整">
                <span>境目</span>
              </div>

              <aside class="mock-sidebar">
                <section>
                  <h2>Profile</h2>
                  <p>さもの</p>
                  <p>文学・哲学・批評理論についての読書メモと短い試論。</p>
                </section>
                <section>
                  <h2>Recent Entries</h2>
                  <p>このブログについて</p>
                  <p>読書メモの表示サンプル</p>
                </section>
                <section>
                  <h2>Categories</h2>
                  <p>読書メモ / 雑記</p>
                </section>
              </aside>
            </div>

            <div class="page-handle" id="pageHandle" role="separator" aria-label="ページ全体の幅を調整">
              <span>全体幅</span>
            </div>
          </div>
        </div>
      </section>

      <section class="readout" aria-label="反映用の値">
        <div>
          <h2>この値を反映する</h2>
          <p>気に入ったら、下の内容をそのまま送ってください。</p>
        </div>
        <textarea id="cssOutput" readonly></textarea>
        <button type="button" id="copyButton">コピー</button>
      </section>
    </main>

    <script>
      // @ts-nocheck
      const state = {
        page: 1160,
        main: 740,
        sidebar: 260,
        gap: 56,
        offset: 18,
        font: 17,
        link: '#5a4a78',
      };

      const ids = [
        'pageRange',
        'mainRange',
        'sidebarRange',
        'gapRange',
        'offsetRange',
        'fontRange',
        'linkColor',
        'pageValue',
        'mainValue',
        'sidebarValue',
        'gapValue',
        'offsetValue',
        'fontValue',
        'cssOutput',
        'copyButton',
        'dividerHandle',
        'pageHandle',
      ];
      const el = Object.fromEntries(ids.map((id) => [id, document.querySelector(`#${id}`)]));

      function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
      }

      function darken(hex) {
        const color = hex.replace('#', '');
        const parts = [0, 2, 4].map((start) => parseInt(color.slice(start, start + 2), 16));
        return `#${parts.map((part) => clamp(part - 28, 0, 255).toString(16).padStart(2, '0')).join('')}`;
      }

      function fitWidths(preferred = 'main') {
        const available = state.page - state.gap;
        const minMain = 620;
        const minSidebar = 220;
        const maxMain = 840;
        const maxSidebar = 340;

        state.main = clamp(state.main, minMain, maxMain);
        state.sidebar = clamp(state.sidebar, minSidebar, maxSidebar);

        if (state.main + state.sidebar !== available) {
          if (preferred === 'sidebar') {
            state.main = available - state.sidebar;
            state.main = clamp(state.main, minMain, maxMain);
            state.sidebar = available - state.main;
          } else {
            state.sidebar = available - state.main;
            state.sidebar = clamp(state.sidebar, minSidebar, maxSidebar);
            state.main = available - state.sidebar;
          }
        }

        state.main = Math.round(state.main);
        state.sidebar = Math.round(state.sidebar);
      }

      function setRangeValues() {
        el.pageRange.value = state.page;
        el.mainRange.value = state.main;
        el.sidebarRange.value = state.sidebar;
        el.gapRange.value = state.gap;
        el.offsetRange.value = state.offset;
        el.fontRange.value = state.font;
        el.linkColor.value = state.link;
      }

      function applyState(preferred = 'main') {
        fitWidths(preferred);
        setRangeValues();
        document.documentElement.style.setProperty('--lab-page-width', `${state.page}px`);
        document.documentElement.style.setProperty('--lab-main-width', `${state.main}px`);
        document.documentElement.style.setProperty('--lab-sidebar-width', `${state.sidebar}px`);
        document.documentElement.style.setProperty('--lab-gap', `${state.gap}px`);
        document.documentElement.style.setProperty('--lab-offset', `${state.offset}px`);
        document.documentElement.style.setProperty('--blog-font-size', `${state.font}px`);
        document.documentElement.style.setProperty('--blog-link', state.link);
        document.documentElement.style.setProperty('--blog-link-hover', darken(state.link));

        el.pageValue.textContent = state.page;
        el.mainValue.textContent = state.main;
        el.sidebarValue.textContent = state.sidebar;
        el.gapValue.textContent = state.gap;
        el.offsetValue.textContent = state.offset;
        el.fontValue.textContent = state.font;
        el.cssOutput.value = [
          `--blog-link: ${state.link};`,
          `--blog-link-hover: ${darken(state.link)};`,
          `--blog-page-width: ${state.page}px;`,
          `--blog-main-width: ${state.main}px;`,
          `--blog-sidebar-width: ${state.sidebar}px;`,
          `--blog-column-gap: ${state.gap}px;`,
          `--blog-sidebar-offset: ${state.offset}px;`,
          `--blog-font-size: ${state.font}px;`,
        ].join('\n');
      }

      function dragDivider(event) {
        event.preventDefault();
        const startX = event.clientX;
        const startMain = state.main;
        const startSidebar = state.sidebar;

        function move(moveEvent) {
          const delta = moveEvent.clientX - startX;
          state.main = clamp(startMain + delta, 620, 840);
          state.sidebar = clamp(startSidebar - delta, 220, 340);
          state.page = state.main + state.sidebar + state.gap;
          applyState('main');
        }

        stopOnPointerUp(move);
      }

      function dragPage(event) {
        event.preventDefault();
        const startX = event.clientX;
        const startPage = state.page;

        function move(moveEvent) {
          const delta = moveEvent.clientX - startX;
          state.page = clamp(startPage + delta, 980, 1240);
          applyState('main');
        }

        stopOnPointerUp(move);
      }

      function stopOnPointerUp(move) {
        function up() {
          window.removeEventListener('pointermove', move);
          window.removeEventListener('pointerup', up);
        }
        window.addEventListener('pointermove', move);
        window.addEventListener('pointerup', up);
      }

      el.pageRange.addEventListener('input', () => {
        state.page = Number(el.pageRange.value);
        applyState('main');
      });
      el.mainRange.addEventListener('input', () => {
        state.main = Number(el.mainRange.value);
        state.page = state.main + state.sidebar + state.gap;
        applyState('main');
      });
      el.sidebarRange.addEventListener('input', () => {
        state.sidebar = Number(el.sidebarRange.value);
        state.page = state.main + state.sidebar + state.gap;
        applyState('sidebar');
      });
      el.gapRange.addEventListener('input', () => {
        state.gap = Number(el.gapRange.value);
        state.page = state.main + state.sidebar + state.gap;
        applyState('main');
      });
      el.offsetRange.addEventListener('input', () => {
        state.offset = Number(el.offsetRange.value);
        applyState('main');
      });
      el.fontRange.addEventListener('input', () => {
        state.font = Number(el.fontRange.value);
        applyState('main');
      });
      el.linkColor.addEventListener('input', () => {
        state.link = el.linkColor.value;
        applyState('main');
      });
      el.dividerHandle.addEventListener('pointerdown', dragDivider);
      el.pageHandle.addEventListener('pointerdown', dragPage);
      el.copyButton.addEventListener('click', async () => {
        await navigator.clipboard.writeText(el.cssOutput.value);
        el.copyButton.textContent = 'コピーしました';
        window.setTimeout(() => {
          el.copyButton.textContent = 'コピー';
        }, 1200);
      });

      applyState('main');
    </script>
  </body>
</html>

<style>
  .lab-page {
    background: var(--blog-background);
  }

  .lab-shell {
    width: min(1360px, calc(100% - 40px));
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
  }

  .lab-header {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--blog-border);
  }

  .eyebrow {
    margin: 0;
    color: var(--blog-link);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.85rem;
  }

  h1 {
    margin: 0.1rem 0 0.35rem;
    font-size: 1.8rem;
    line-height: 1.35;
  }

  .lab-header p:last-child {
    margin: 0;
    color: var(--blog-muted-text);
  }

  .control-panel,
  .preview-area,
  .readout {
    border: 1px solid var(--blog-border);
    background: var(--blog-surface);
  }

  .control-panel {
    position: sticky;
    top: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(7, minmax(130px, 1fr));
    gap: 0.85rem;
    padding: 0.9rem;
    box-shadow: 0 8px 20px rgba(31, 31, 31, 0.06);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.86rem;
  }

  label {
    display: grid;
    gap: 0.35rem;
  }

  input[type='range'] {
    width: 100%;
  }

  input[type='color'] {
    width: 100%;
    height: 38px;
    border: 1px solid var(--blog-border);
    background: var(--blog-surface);
  }

  output {
    color: var(--blog-link);
    font-weight: 700;
  }

  .preview-area {
    margin-top: 1rem;
  }

  .preview-toolbar {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--blog-border);
    color: var(--blog-muted-text);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.9rem;
  }

  .preview-toolbar p {
    margin: 0;
  }

  .preview-canvas {
    overflow-x: auto;
    padding: 32px 48px 42px;
    background:
      linear-gradient(90deg, rgba(90, 74, 120, 0.08) 1px, transparent 1px),
      linear-gradient(180deg, rgba(90, 74, 120, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .mock-page {
    --lab-page-width: 1160px;
    --lab-main-width: 740px;
    --lab-sidebar-width: 260px;
    --lab-gap: 56px;
    --lab-offset: 18px;
    position: relative;
    width: var(--lab-page-width);
    min-width: 920px;
    margin: 0 auto;
    padding: 26px;
    border: 2px solid color-mix(in srgb, var(--blog-link) 42%, var(--blog-border));
    background: var(--blog-background);
    box-shadow: 0 16px 40px rgba(31, 31, 31, 0.09);
  }

  .mock-header {
    margin-bottom: 22px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--blog-border);
  }

  .mock-header strong {
    display: block;
    font-size: 2rem;
    line-height: 1.2;
  }

  .mock-header span {
    color: var(--blog-muted-text);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.9rem;
  }

  .mock-layout {
    position: relative;
    display: grid;
    grid-template-columns: var(--lab-main-width) var(--lab-sidebar-width);
    gap: var(--lab-gap);
    align-items: start;
  }

  .mock-main,
  .mock-sidebar {
    min-height: 390px;
    background: var(--blog-background);
  }

  .mock-main {
    padding: 0;
  }

  .mock-main h2 {
    margin: 0.2rem 0 1rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--blog-border);
    font-size: 1.45rem;
  }

  .mock-main blockquote {
    margin-bottom: 0;
  }

  .mock-meta {
    margin: 0;
    color: var(--blog-muted-text);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.85rem;
  }

  .mock-sidebar {
    margin-top: var(--lab-offset);
    color: var(--blog-muted-text);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .mock-sidebar section {
    margin-bottom: 1.1rem;
    padding-bottom: 1.1rem;
    border-bottom: 1px solid var(--blog-border);
  }

  .mock-sidebar h2 {
    margin: 0 0 0.45rem;
    color: var(--blog-text);
    font-size: 0.95rem;
  }

  .mock-sidebar p {
    margin: 0.25rem 0;
  }

  .divider-handle,
  .page-handle {
    position: absolute;
    z-index: 2;
    display: grid;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--blog-link) 52%, var(--blog-border));
    background: color-mix(in srgb, var(--blog-link) 20%, var(--blog-surface));
    color: var(--blog-link);
    cursor: ew-resize;
    touch-action: none;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    user-select: none;
  }

  .divider-handle {
    top: 74px;
    bottom: 42px;
    left: calc(var(--lab-main-width) + (var(--lab-gap) / 2) - 12px);
    width: 24px;
  }

  .page-handle {
    top: 50%;
    right: -13px;
    width: 26px;
    height: 170px;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
  }

  .divider-handle span {
    writing-mode: vertical-rl;
  }

  .readout {
    display: grid;
    grid-template-columns: 260px 1fr 120px;
    gap: 1rem;
    align-items: center;
    margin-top: 1rem;
    padding: 1rem;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .readout h2 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
  }

  .readout p {
    margin: 0;
    color: var(--blog-muted-text);
    font-size: 0.88rem;
  }

  textarea {
    width: 100%;
    min-height: 118px;
    resize: vertical;
    border: 1px solid var(--blog-border);
    padding: 0.75rem;
    background: var(--blog-background);
    color: var(--blog-text);
    font: 0.82rem/1.6 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  }

  button {
    border: 1px solid var(--blog-link);
    padding: 0.65rem 0.9rem;
    background: var(--blog-link);
    color: white;
    font: inherit;
    cursor: pointer;
  }

  @media (max-width: 1050px) {
    .control-panel {
      grid-template-columns: repeat(2, minmax(130px, 1fr));
      position: static;
    }

    .readout {
      display: block;
    }

    textarea,
    button {
      margin-top: 0.75rem;
    }

    button {
      width: 100%;
    }
  }
</style>

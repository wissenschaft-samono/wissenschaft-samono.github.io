---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatDate, getAllPosts, getArchiveYears } from '@/lib/posts';

const archiveYears = getArchiveYears(await getAllPosts());
---

<BaseLayout title="Archive">
  <h1 class="page-title">Archive</h1>
  <div class="archive">
    {archiveYears.map(([year, posts]) => (
      <section>
        <h2>{year}</h2>
        <ol>
          {posts.map((post) => (
            <li>
              <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              <span>{post.data.category}</span>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .archive section {
    margin-bottom: 2rem;
  }

  h2 {
    border-bottom: 1px solid var(--line);
    font-size: 1.25rem;
  }

  ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li {
    display: grid;
    grid-template-columns: 8.5rem 1fr auto;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--line);
  }

  time,
  span {
    color: var(--muted);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 0.86rem;
  }

  @media (max-width: 640px) {
    li {
      display: block;
    }

    time,
    span {
      display: block;
    }
  }
</style>
